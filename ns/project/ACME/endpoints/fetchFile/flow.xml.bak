<?xml version="1.0" encoding="UTF-8"?>

<FLOW VERSION="3.2" CLEANUP="true">
  <COMMENT>Fetch a single remote file as a string.</COMMENT>

  <!-- nodes -->

<INVOKE TIMEOUT="" SERVICE="project.partner_acme_1.endpoints:getSftpConfig" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT>config</COMMENT>
</INVOKE>

<INVOKE TIMEOUT="" SERVICE="pub.client.sftp:login" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT>login</COMMENT>

  <!-- nodes -->

<MAP MODE="INPUT">

  <!-- nodes -->

<MAPCOPY FROM="/sftp/userAlias;0;0" TO="/userAlias;0;0">
</MAPCOPY>
</MAP>

<MAP MODE="OUTPUT">

  <!-- nodes -->

<MAPCOPY FROM="/sessionKey;0;0" TO="/sessionKey;0;0">
</MAPCOPY>
</MAP>
</INVOKE>

<INVOKE TIMEOUT="" SERVICE="pub.client.sftp:get" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT>download</COMMENT>

  <!-- nodes -->

<MAP MODE="INPUT">

  <!-- nodes -->

<MAPCOPY FROM="/sessionKey;0;0" TO="/sessionKey;0;0">
</MAPCOPY>

<MAPCOPY FROM="/remoteFile;0;0" TO="/remoteFile;0;0">
</MAPCOPY>
</MAP>

<MAP MODE="OUTPUT">

  <!-- nodes -->

<MAPCOPY FROM="/returnCode;0;0" TO="/returnCode;0;0">
</MAPCOPY>
</MAP>
</INVOKE>

<INVOKE TIMEOUT="" SERVICE="pub.io:streamToString" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT>bytes -&gt; text</COMMENT>

  <!-- nodes -->

<MAP MODE="INPUT">

  <!-- nodes -->

<MAPCOPY FROM="/contentStream;0;0" TO="/inputStream;0;0">
</MAPCOPY>
</MAP>

<MAP MODE="OUTPUT">

  <!-- nodes -->

<MAPCOPY FROM="/string;0;0" TO="/content;0;0">
</MAPCOPY>
</MAP>
</INVOKE>

<INVOKE TIMEOUT="" SERVICE="pub.client.sftp:logout" VALIDATE-IN="$none" VALIDATE-OUT="$none">
  <COMMENT>logout</COMMENT>

  <!-- nodes -->

<MAP MODE="INPUT">

  <!-- nodes -->

<MAPCOPY FROM="/sessionKey;0;0" TO="/sessionKey;0;0">
</MAPCOPY>
</MAP>
</INVOKE>

<MAP MODE="STANDALONE">

  <!-- nodes -->

<MAPDELETE FIELD="/sftp">
</MAPDELETE>

<MAPDELETE FIELD="/sessionKey">
</MAPDELETE>

<MAPDELETE FIELD="/contentStream">
</MAPDELETE>
</MAP>
</FLOW>
